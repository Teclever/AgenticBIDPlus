# Runtime state — never committed (see MASTER_ACTION_PLAN_V3.md #21 / §5b)
*.db
*-wal
*-shm
exports/
downloads/
.browser_profile/
.env
*.nosync

# Secrets stay out (templates like .env.example are fine and kept)
# (no bids/ entry — staging lives under $BIDPLUS_RUNTIME_DIR, outside the tree)

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/

# Node / web app (webapp-design/, UIReference/) — deps + build output, not source.
# Lockfiles (package-lock.json / pnpm-lock.yaml) stay tracked.
node_modules/
dist/
build/
.vite/
.next/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# OS / editor cruft
.DS_Store

# Local scratch
_oldFiles/
